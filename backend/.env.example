# Copy to backend/.env and adjust. All vars are prefixed with HUB_.

# --- App ---
HUB_APP_NAME=AI Port Hub
HUB_HOST=0.0.0.0
HUB_PORT=8000
HUB_DEBUG=false

# --- Admin bootstrap (first run only) ---
HUB_ADMIN_USERNAME=admin
# If left empty, a random password is generated and printed to the console once.
HUB_ADMIN_PASSWORD=

# --- Security ---
# If empty, a stable key is generated and stored at data/secret.key
HUB_SECRET_KEY=
HUB_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Database (default: SQLite at data/hub.db) ---
# HUB_DATABASE_URL=sqlite:///./data/hub.db

# --- Defaults for new port services ---
HUB_DEFAULT_REQUEST_TIMEOUT=120
HUB_DEFAULT_MAX_RETRIES=2
HUB_DEFAULT_CONCURRENCY=8
HUB_DEFAULT_LOG_KEEP=10
